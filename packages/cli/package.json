    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "jiti": "^2.4.0",
    "tinyglobby": "^0.2.10",
    "tutorial-forge": "workspace:*"
  },
  "devDependencies": {
    "playwright": "^1.59.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
