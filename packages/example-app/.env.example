# Copy to .env and fill in. The forge CLI loads .env from the directory you run it in.
# TTS provider: silent (default, no key needed) | elevenlabs | openai
FORGE_TTS=elevenlabs
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9
# Per-language voices (fall back to ELEVENLABS_VOICE_ID when unset).
# Underscores become dashes in region tags: ..._PT_BR → pt-BR.
# ELEVENLABS_VOICE_ID_ES=
# ELEVENLABS_VOICE_ID_FR=
# OPENAI_API_KEY=
