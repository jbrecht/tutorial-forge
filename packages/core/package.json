{
  "name": "tutorial-forge",
  "version": "0.9.0",
  "description": "Turn scripted Playwright walkthroughs into narrated tutorial videos (MP4). Tutorials are source code: re-render instead of re-recording when your UI changes.",
  "type": "module",
  "license": "MIT",
  "author": "John Brecht <john.brecht@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jbrecht/tutorial-forge.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/jbrecht/tutorial-forge#readme",
  "bugs": "https://github.com/jbrecht/tutorial-forge/issues",
  "keywords": [
    "playwright",
    "tutorial",
    "video",
    "screen-recording",
    "tts",
    "narration",
    "documentation",
    "ffmpeg",
    "elevenlabs",
    "demo"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "execa": "^9.5.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "playwright": "^1.59.0"
  },
  "devDependencies": {
    "playwright": "^1.59.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
