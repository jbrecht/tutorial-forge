{
  "name": "tutorial-forge",
  "version": "0.1.0",
  "description": "Turn scripted Playwright walkthroughs into narrated tutorial videos",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
